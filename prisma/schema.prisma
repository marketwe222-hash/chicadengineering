// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
 
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  STUDENT
  ADMIN
  SUPER_ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  SUSPENDED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum GradeScale {
  A_PLUS
  A
  A_MINUS
  B_PLUS
  B
  B_MINUS
  C_PLUS
  C
  C_MINUS
  D
  F
}

enum CourseStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum AcademicTermType {
  SEMESTER
  TRIMESTER
  QUARTER
}

// ─────────────────────────────────────────
// USER (Base auth model)
// ─────────────────────────────────────────

model User {
  id             String    @id @default(cuid())
  email          String?   @unique
  passwordHash   String
  role           Role      @default(STUDENT)
  isActive       Boolean   @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  // Relations
  student        Student?
  admin          Admin?
  sessions       Session[]
  auditLogs      AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────
// SESSION (Token management)
// ─────────────────────────────────────────

model Session {
  id           String   @id @default(cuid())
  userId       String
  token        String   @unique
  expiresAt    DateTime
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// ─────────────────────────────────────────
// STUDENT
// ─────────────────────────────────────────

model Student {
  id               String           @id @default(cuid())
  userId           String           @unique
  studentId        String           @unique  // e.g. "ACA-2024-0001"
  firstName        String
  lastName         String
  middleName       String?
  dateOfBirth      DateTime
  gender           Gender
  phone            String?
  address          String?
  profileImage     String?
  status           EnrollmentStatus @default(ACTIVE)
  enrolledAt       DateTime         @default(now())
  graduatedAt      DateTime?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  user             User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments      Enrollment[]
  attendances      Attendance[]
  grades           Grade[]
  payments         Payment[]
  emergencyContact EmergencyContact?
  documents        Document[]

  @@index([studentId])
  @@index([status])
  @@map("students")
}

// ─────────────────────────────────────────
// EMERGENCY CONTACT
// ─────────────────────────────────────────

model EmergencyContact {
  id           String  @id @default(cuid())
  studentId    String  @unique
  name         String
  relationship String
  phone        String
  email        String?

  // Relations
  student      Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@map("emergency_contacts")
}

// ─────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  userId       String   @unique
  firstName    String
  lastName     String
  department   String?
  phone        String?
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relations
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

// ─────────────────────────────────────────
// ACADEMIC TERM
// ─────────────────────────────────────────

model AcademicTerm {
  id          String           @id @default(cuid())
  name        String           // e.g. "Fall 2024"
  type        AcademicTermType @default(SEMESTER)
  startDate   DateTime
  endDate     DateTime
  isActive    Boolean          @default(false)
  createdAt   DateTime         @default(now())

  // Relations
  courses     Course[]
  enrollments Enrollment[]

  @@map("academic_terms")
}

// ─────────────────────────────────────────
// DEPARTMENT
// ─────────────────────────────────────────

model Department {
  id          String   @id @default(cuid())
  name        String   @unique  // e.g. "Civil Engineering"
  code        String   @unique  // e.g. "CE"
  description String?
  createdAt   DateTime @default(now())

  // Relations
  courses     Course[]

  @@map("departments")
}

// ─────────────────────────────────────────
// COURSE
// ─────────────────────────────────────────

model Course {
  id             String       @id @default(cuid())
  courseCode     String       @unique  // e.g. "CE-101"
  name           String
  description    String?
  credits        Int          @default(3)
  maxStudents    Int          @default(30)
  status         CourseStatus @default(ACTIVE)
  departmentId   String
  academicTermId String
  instructorName String?
  schedule       String?      // e.g. "Mon/Wed 9:00-10:30"
  room           String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
   lessons     Lesson[]   // add this line
  // Relations
  department     Department   @relation(fields: [departmentId], references: [id])
  academicTerm   AcademicTerm @relation(fields: [academicTermId], references: [id])
  enrollments    Enrollment[]
  attendances    Attendance[]
  grades         Grade[]

  @@index([courseCode])
  @@index([status])
  @@map("courses")
}

// ─────────────────────────────────────────
// ENROLLMENT
// ─────────────────────────────────────────

model Enrollment {
  id             String           @id @default(cuid())
  studentId      String
  courseId       String
  academicTermId String
  status         EnrollmentStatus @default(ACTIVE)
  enrolledAt     DateTime         @default(now())
  droppedAt      DateTime?

  // Relations
  student        Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course         Course           @relation(fields: [courseId], references: [id])
  academicTerm   AcademicTerm     @relation(fields: [academicTermId], references: [id])

  @@unique([studentId, courseId, academicTermId])
  @@index([studentId])
  @@index([courseId])
  @@map("enrollments")
}

// ─────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  courseId  String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime         @default(now())

  // Relations
  student   Student          @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course    Course           @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId, date])
  @@index([studentId])
  @@index([courseId])
  @@index([date])
  @@map("attendances")
}

// ─────────────────────────────────────────
// GRADE
// ─────────────────────────────────────────

model Grade {
  id          String     @id @default(cuid())
  studentId   String
  courseId    String
  score       Float      // numeric score e.g. 87.5
  gradeScale  GradeScale
  remarks     String?
  gradedAt    DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  // Relations
  student     Student    @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course      Course     @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@index([studentId])
  @@map("grades")
}

// ─────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentType {
  TUITION
  REGISTRATION
  EXAM_FEE
  LIBRARY
  OTHER
}

model Payment {
  id            String        @id @default(cuid())
  studentId     String
  amount        Decimal       @db.Decimal(10, 2)
  type          PaymentType
  status        PaymentStatus @default(PENDING)
  dueDate       DateTime
  paidAt        DateTime?
  referenceNo   String?       @unique
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  student       Student       @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@map("payments")
}

// ─────────────────────────────────────────
// DOCUMENT
// ─────────────────────────────────────────

enum DocumentType {
  ID_CARD
  TRANSCRIPT
  CERTIFICATE
  ENROLLMENT_FORM
  OTHER
}

model Document {
  id          String       @id @default(cuid())
  studentId   String
  type        DocumentType
  fileName    String
  fileUrl     String
  uploadedAt  DateTime     @default(now())

  // Relations
  student     Student      @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("documents")
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  userId     String
  action     String   // e.g. "STUDENT_CREATED", "GRADE_UPDATED"
  entity     String   // e.g. "Student", "Grade"
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  createdAt  DateTime @default(now())

  // Relations
  user       User     @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────

enum NotificationType {
  GRADE_POSTED
  ATTENDANCE_ALERT
  PAYMENT_DUE
  ANNOUNCEMENT
  SYSTEM
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}


enum LessonStatus {
  DRAFT
  PUBLISHED
}

model Lesson {
  id          String       @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int          @default(0)
  duration    Int?         // minutes
  status      LessonStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  // Relations
  course      Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  resources   LessonResource[]

  @@index([courseId])
  @@map("lessons")
}

enum ResourceType {
  VIDEO
  PDF
  IMAGE
}

model LessonResource {
  id         String       @id @default(cuid())
  lessonId   String
  type       ResourceType
  fileName   String
  fileUrl    String
  fileSize   Int?         // bytes
  createdAt  DateTime     @default(now())

  // Relations
  lesson     Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_resources")
}