// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────

enum Role {
  STUDENT
  ADMIN
  SUPER_ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EnrollmentStatus {
  ACTIVE
  INACTIVE
  GRADUATED
  SUSPENDED
  WITHDRAWN
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  EXCUSED
}

enum GradeScale {
  A_PLUS
  A
  A_MINUS
  B_PLUS
  B
  B_MINUS
  C_PLUS
  C
  C_MINUS
  D
  F
}

enum CourseStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PaymentStatus {
  PENDING
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentType {
  TUITION
  REGISTRATION
  EXAM_FEE
  OTHER
}

enum DocumentType {
  ID_CARD
  TRANSCRIPT
  CERTIFICATE
  ENROLLMENT_FORM
  OTHER
}

enum NotificationType {
  GRADE_POSTED
  ATTENDANCE_ALERT
  PAYMENT_DUE
  ANNOUNCEMENT
  SYSTEM
}

enum LessonStatus {
  DRAFT
  PUBLISHED
}

// Type of media attached to a course or lesson
enum MediaType {
  VIDEO
  PDF
  DOCUMENT
  IMAGE
}

// How the student heard about CHICAD
enum HowHeard {
  SOCIAL_MEDIA
  FRIEND
  OTHER
}

// Student background status
enum StudentBackground {
  STUDENT
  GRADUATE
  PROFESSIONAL
}

// Current skill level when enrolling
enum SkillLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

// ─────────────────────────────────────────
// USER  (base auth model)
// ─────────────────────────────────────────

model User {
  id           String    @id @default(cuid())
  email        String?   @unique
  passwordHash String
  role         Role      @default(STUDENT)
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  student   Student?
  admin     Admin?
  sessions  Session[]
  auditLogs AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────
// SESSION
// ─────────────────────────────────────────

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("sessions")
}

// ─────────────────────────────────────────
// STUDENT
// ─────────────────────────────────────────

model Student {
  id           String           @id @default(cuid())
  userId       String           @unique
  studentId    String           @unique // e.g. "ACA-2024-0001"

  // Personal info
  firstName    String
  lastName     String
  phone        String?
  city         String?
  profileImage String?

  // Academic background (from registration form)
  background   StudentBackground?  // student / graduate / professional
  school       String?             // school or workplace
  fieldOfStudy String?             // civil eng, architecture, etc.
emergencyContact  EmergencyContact?
  // Motivation (from registration form)
  whyEnrolled  String?             // why they chose this software
  skillLevel   SkillLevel?         // beginner / intermediate / advanced
  howHeard     HowHeard?           // social media / friend / other
  referrer     String?             // name of person who referred them

  // Engagement
  followsSocial  Boolean @default(false)
  joinChallenge  Boolean @default(false)

  // Batch info
  batch        Int?                // e.g. 11
  status       EnrollmentStatus    @default(ACTIVE)
  enrolledAt   DateTime            @default(now())
  graduatedAt  DateTime?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt

  // Relations
  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  enrollments Enrollment[]      // array of courses the student is enrolled in
  attendances Attendance[]
  certificates    Certificate[]
  lessonProgress LessonProgress[]
  grades      Grade[]
  payments    Payment[]
  documents   Document[]

  @@index([studentId])
  @@index([status])
  @@map("students")
}


model EmergencyContact {
  id           String  @id @default(cuid())
  studentId    String  @unique
  student      Student @relation(fields: [studentId], references: [id])

  name         String
  relationship String
  phone        String
  email        String?
}
// ─────────────────────────────────────────
// ADMIN
// ─────────────────────────────────────────

model Admin {
  id           String   @id @default(cuid())
  userId       String   @unique
  firstName    String
  lastName     String
  department   String?
  phone        String?
  profileImage String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admins")
}

// ─────────────────────────────────────────
// COURSE
// ─────────────────────────────────────────

model Course {
  id              String       @id @default(cuid())
  courseCode      String       @unique // e.g. "AUTOCAD-B11"
  name            String                // e.g. "AutoCAD"
  category        String                // e.g. "CAD", "BIM", "FEA"
  icon            String?               // emoji e.g. "📐"
  description     String?
  registrationFee Int          @default(5000)   // FRS
  trainingFee     Int          @default(70000)  // FRS
  durationMonths  Int          @default(3)
  maxStudents     Int          @default(30)
  status          CourseStatus @default(ACTIVE)
  batch           Int?                  // which batch this course runs in
  instructorName  String?
  schedule        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  // Relations
  enrollments Enrollment[]
  attendances Attendance[]
  certificates    Certificate[]
  grades      Grade[]
  lessons     Lesson[]
  media       CourseMedia[]   // videos & documents at course level

  @@index([courseCode])
  @@index([status])
  @@map("courses")
}

// ─────────────────────────────────────────
// COURSE MEDIA  (videos & documents)
// ─────────────────────────────────────────

model CourseMedia {
  id          String    @id @default(cuid())
  courseId    String
  type        MediaType           // VIDEO | PDF | DOCUMENT | IMAGE
  title       String
  description String?
  fileUrl     String              // storage URL
  fileName    String?
  fileSize    Int?                // bytes
  duration    Int?                // seconds (for videos)
  order       Int       @default(0)
  isPublished Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@index([courseId])
  @@index([type])
  @@map("course_media")
}

// ─────────────────────────────────────────
// LESSON  (ordered units within a course)
// ─────────────────────────────────────────

model Lesson {
  id          String       @id @default(cuid())
  courseId    String
  title       String
  description String?
  order       Int          @default(0)
  duration    Int?         // minutes
  status      LessonStatus @default(DRAFT)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  course    Course          @relation(fields: [courseId], references: [id], onDelete: Cascade)
  resources LessonResource[]
  progress LessonProgress[]

  @@index([courseId])
  @@map("lessons")
}

model Certificate {
  id          String   @id @default(cuid())
  studentId   String
  courseId    String
  issuedAt    DateTime @default(now())
  fileUrl     String?

  student Student @relation(fields: [studentId], references: [id])
  course  Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@map("certificates")
}

// ─────────────────────────────────────────
// LESSON RESOURCE  (media attached to a lesson)
// ─────────────────────────────────────────

model LessonResource {
  id        String    @id @default(cuid())
  lessonId  String
  type      MediaType
  title     String?
  fileName  String
  fileUrl   String
  fileSize  Int?      // bytes
  duration  Int?      // seconds (for videos)
  order     Int       @default(0)
  createdAt DateTime  @default(now())

  lesson Lesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@index([lessonId])
  @@map("lesson_resources")
}

// ─────────────────────────────────────────
// ENROLLMENT  (student ↔ course, many-to-many)
// ─────────────────────────────────────────

model Enrollment {
  id         String           @id @default(cuid())
  studentId  String
  courseId   String
  status     EnrollmentStatus @default(ACTIVE)
  progress   Int              @default(0)  // 0-100 %
  enrolledAt DateTime         @default(now())
  droppedAt  DateTime?

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@index([studentId])
  @@index([courseId])
  @@map("enrollments")
}

// ─────────────────────────────────────────
// ATTENDANCE
// ─────────────────────────────────────────

model Attendance {
  id        String           @id @default(cuid())
  studentId String
  courseId  String
  date      DateTime
  status    AttendanceStatus @default(PRESENT)
  notes     String?
  createdAt DateTime         @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId, date])
  @@index([studentId])
  @@index([courseId])
  @@index([date])
  @@map("attendances")
}

// ─────────────────────────────────────────
// GRADE
// ─────────────────────────────────────────

model Grade {
  id         String     @id @default(cuid())
  studentId  String
  courseId   String
  score      Float
  gradeScale GradeScale
  remarks    String?
  gradedAt   DateTime   @default(now())
  updatedAt  DateTime   @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  course  Course  @relation(fields: [courseId], references: [id])

  @@unique([studentId, courseId])
  @@index([studentId])
  @@map("grades")
}

// ─────────────────────────────────────────
// PAYMENT
// ─────────────────────────────────────────

model Payment {
  id          String        @id @default(cuid())
  studentId   String
  amount      Decimal       @db.Decimal(10, 2)
  type        PaymentType
  status      PaymentStatus @default(PENDING)
  dueDate     DateTime
  paidAt      DateTime?
  referenceNo String?       @unique
  momoNumber  String?       // MoMo number used
  notes       String?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@index([status])
  @@map("payments")
}

// ─────────────────────────────────────────
// DOCUMENT
// ─────────────────────────────────────────

model Document {
  id         String       @id @default(cuid())
  studentId  String
  type       DocumentType
  fileName   String
  fileUrl    String
  uploadedAt DateTime     @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)

  @@index([studentId])
  @@map("documents")
}

// ─────────────────────────────────────────
// AUDIT LOG
// ─────────────────────────────────────────

model AuditLog {
  id        String   @id @default(cuid())
  userId    String
  action    String
  entity    String
  entityId  String?
  oldValues Json?
  newValues Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entity, entityId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────
// NOTIFICATION
// ─────────────────────────────────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  message   String
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  @@index([userId, isRead])
  @@map("notifications")
}

model LessonProgress {
  id          String   @id @default(cuid())
  studentId   String
  lessonId    String
  completed   Boolean  @default(false)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  student Student @relation(fields: [studentId], references: [id], onDelete: Cascade)
  lesson  Lesson  @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@unique([studentId, lessonId])
  @@index([studentId])
  @@map("lesson_progress")
}